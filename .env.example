APP_NAME=APEX v4 Binance
ENV=dev
DRY_RUN=true
BINANCE_TESTNET=true
BINANCE_API_KEY=your_key
BINANCE_API_SECRET=your_secret
BINANCE_MARKET_TYPE=spot
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_OPENAI_ENABLED=false
AI_CLAUDE_ENABLED=false
