APP_NAME=APEX AI Trading Platform
ENV=dev
DRY_RUN=true

# Active exchange: bitget or binance
EXCHANGE=bitget

# Binance
BINANCE_TESTNET=true
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_MARKET_TYPE=spot

# Bitget
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSWORD=
BITGET_MARKET_TYPE=spot

# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

AI_OPENAI_ENABLED=false
AI_CLAUDE_ENABLED=false

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Storage
DATABASE_URL=sqlite+aiosqlite:///./data/apex.db

SCAN_INTERVAL_SECONDS=60
MAX_RISK_PER_TRADE=0.005
MAX_DAILY_LOSS=0.03
MAX_WEEKLY_LOSS=0.08
MAX_CONCURRENT_TRADES=3
DEFAULT_LEVERAGE=1
MAX_LEVERAGE=3
CONSENSUS_THRESHOLD=0.65
MIN_CONFIDENCE_SCORE=0.70
SIGNAL_CONFLUENCE_REQUIRED=4
PREFERRED_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,AVAX/USDT
